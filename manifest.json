{
  "manifest_version": 3,
  "name": "My Custom PDF Viewer",
  "version": "1.0",
  "description": "自定义 PDF 查看器，支持夜间模式",
  "permissions": [
    "webNavigation",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pdfjs/**/*",
        "viewer-wrapper.html",
        "viewer-wrapper.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
